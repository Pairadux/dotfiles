#!/bin/bash
# usage: wallpaper-set <name|path> [--generate] [--write] [--list]

WALLPAPER_DIR="/home/austincgause/Media/Pictures/wallpapers"
HYPRPAPER_CONF="/home/austincgause/.config/hypr/hyprpaper.conf"

# Flags
GENERATE=0
WRITE=0
LIST=0
INPUT=""

for arg in "$@"; do
    case "$arg" in
        --generate) GENERATE=1 ;;
        --write)    WRITE=1 ;;
        --list)     LIST=1 ;;
        *)          INPUT="$arg" ;;
    esac
done

# --list: scan two levels deep for valid $basename-wallpaper/top.png + bottom.png
if [[ $LIST -eq 1 ]]; then
    echo "Available wallpaper pairs:"
    for top in "$WALLPAPER_DIR"/*/*-wallpaper/top.png; do
        dir=$(dirname "$top")
        bottom="$dir/bottom.png"
        if [[ -f "$bottom" ]]; then
            rel="${dir#"$WALLPAPER_DIR"/}"
            echo "  $rel"
        fi
    done
    exit 0
fi

if [[ -z "$INPUT" ]]; then
    echo "Usage: wallpaper-set <name|path> [--generate] [--write] [--list]"
    exit 1
fi

# Resolve wallpaper dir — accept either "2b" or "2b/2b-wallpaper"
if [[ "$INPUT" == */*-wallpaper ]]; then
    # explicit path: 2b/2b-wallpaper
    WALLPAPER_PAIR="$WALLPAPER_DIR/$INPUT"
    BASENAME=$(basename "$INPUT" | sed 's/-wallpaper$//')
    FLAT="$WALLPAPER_DIR/$(dirname "$INPUT")/${BASENAME}-wallpaper.png"
else
    # short form: 2b → 2b/2b-wallpaper
    BASENAME="$INPUT"
    WALLPAPER_PAIR="$WALLPAPER_DIR/$BASENAME/${BASENAME}-wallpaper"
    FLAT="$WALLPAPER_DIR/$BASENAME/${BASENAME}-wallpaper.png"
fi

TOP="$WALLPAPER_PAIR/top.png"
BOTTOM="$WALLPAPER_PAIR/bottom.png"

# --generate: slice flat PNG with rwpspread
if [[ $GENERATE -eq 1 ]]; then
    if [[ ! -f "$FLAT" ]]; then
        echo "Error: flat source not found at $FLAT"
        exit 1
    fi

    echo "Generating from $FLAT..."
    mkdir -p "$WALLPAPER_PAIR"

    rwpspread --ppi \
        --monitors "HDMI-A-1:27" "DP-2:27" \
        --bezel 83 \
        -o "$WALLPAPER_PAIR" \
        -i "$FLAT"

    # rename hash-named files to top/bottom
    mv "$WALLPAPER_PAIR"/rwps_HDMI-A-1_*.png "$TOP"
    mv "$WALLPAPER_PAIR"/rwps_DP-2_*.png "$BOTTOM"

    echo "Saved to $WALLPAPER_PAIR"
fi

# Check pair exists
if [[ ! -f "$TOP" ]] || [[ ! -f "$BOTTOM" ]]; then
    echo "Error: top.png/bottom.png not found in $WALLPAPER_PAIR"
    echo "Run with --generate to create them from ${BASENAME}-wallpaper.png"
    exit 1
fi

# Apply live
hyprctl hyprpaper wallpaper "HDMI-A-1,$TOP"
hyprctl hyprpaper wallpaper "DP-2,$BOTTOM"
echo "Applied: $WALLPAPER_PAIR"

# --write: write hyprpaper config permanently
if [[ $WRITE -eq 1 ]]; then
    cat > "$HYPRPAPER_CONF" << EOF
wallpaper {
    monitor = HDMI-A-1
    path = $TOP
    fit_mode = stretch
}
wallpaper {
    monitor = DP-2
    path = $BOTTOM
    fit_mode = stretch
}
ipc = on
splash = false
EOF
echo "Config written: $HYPRPAPER_CONF"
fi
