#!/bin/bash
# usage: wallpaper-ctl <name> [--generate] [--write] [--set] [--list]
#
# Manages wallpaper pairs for a dual-monitor hyprpaper setup.
#
#   --list       show available wallpaper pairs
#   --generate   slice a flat source PNG into top/bottom via rwpspread
#   --write      persist the selection to hyprpaper-wallpaper.conf
#   --set        apply live via hyprctl and persist to config
#
# With no flags, shows info about the named wallpaper.

WALLPAPER_DIR="$HOME/Media/Pictures/wallpapers"
WALLPAPER_CONF="$HOME/.config/hypr/hyprpaper-wallpaper.conf"

GENERATE=0
LIST=0
WRITE=0
SET=0
INPUT=""

for arg in "$@"; do
    case "$arg" in
        --generate) GENERATE=1 ;;
        --list)     LIST=1 ;;
        --write)    WRITE=1 ;;
        --set)      SET=1 ;;
        *)          INPUT="$arg" ;;
    esac
done

# --list: show available wallpaper pairs
if [[ $LIST -eq 1 ]]; then
    echo "Available wallpaper pairs:"
    for dir in "$WALLPAPER_DIR"/*/; do
        name=$(basename "$dir")
        pair="$dir/${name}-wallpaper"
        [[ -f "$pair/top.png" && -f "$pair/bottom.png" ]] && echo "  $name"
    done
    exit 0
fi

if [[ -z "$INPUT" ]]; then
    echo "Usage: wallpaper-ctl <name> [--generate] [--write] [--set] [--list]"
    echo ""
    echo "Options:"
    echo "  --list       show available wallpaper pairs"
    echo "  --generate   slice flat source PNG into top/bottom via rwpspread"
    echo "  --write      persist selection to hyprpaper-wallpaper.conf"
    echo "  --set        apply live and persist to config"
    echo ""
    echo "With no flags, shows info about the named wallpaper."
    exit 1
fi

BASENAME="$INPUT"
WALLPAPER_PAIR="$WALLPAPER_DIR/$BASENAME/${BASENAME}-wallpaper"
FLAT="$WALLPAPER_DIR/$BASENAME/${BASENAME}-wallpaper.png"
TOP="$WALLPAPER_PAIR/top.png"
BOTTOM="$WALLPAPER_PAIR/bottom.png"

# --generate: slice flat PNG with rwpspread
if [[ $GENERATE -eq 1 ]]; then
    if [[ ! -f "$FLAT" ]]; then
        echo "Error: flat source not found at $FLAT"
        exit 1
    fi

    echo "Generating from $FLAT..."
    mkdir -p "$WALLPAPER_PAIR"

    rwpspread --ppi \
        --monitors "HDMI-A-1:27" "DP-2:27" \
        --bezel 83 \
        -o "$WALLPAPER_PAIR" \
        -i "$FLAT"

    mv "$WALLPAPER_PAIR"/rwps_HDMI-A-1_*.png "$TOP"
    mv "$WALLPAPER_PAIR"/rwps_DP-2_*.png "$BOTTOM"

    echo "Saved to $WALLPAPER_PAIR"
fi

# --write and --set require the pair to exist
if [[ $WRITE -eq 1 || $SET -eq 1 ]]; then
    if [[ ! -f "$TOP" ]] || [[ ! -f "$BOTTOM" ]]; then
        echo "Error: top.png/bottom.png not found in $WALLPAPER_PAIR"
        echo "Run with --generate to create them from ${BASENAME}-wallpaper.png"
        exit 1
    fi
fi

# --set: apply live and persist
if [[ $SET -eq 1 ]]; then
    hyprctl hyprpaper wallpaper "HDMI-A-1,$TOP"
    hyprctl hyprpaper wallpaper "DP-2,$BOTTOM"
    WRITE=1
    echo "Applied: $BASENAME"
fi

# --write: persist for next boot
if [[ $WRITE -eq 1 ]]; then
    cat > "$WALLPAPER_CONF" <<EOF
\$wallpaper_top = $TOP
\$wallpaper_bottom = $BOTTOM
EOF
    echo "Written: $WALLPAPER_CONF"
fi

# Default (no action flags): show info about the wallpaper
if [[ $GENERATE -eq 0 && $WRITE -eq 0 && $SET -eq 0 ]]; then
    echo "Wallpaper: $BASENAME"
    echo "  Directory: $WALLPAPER_DIR/$BASENAME"

    if [[ -f "$FLAT" ]]; then
        echo "  Flat source: found"
    else
        echo "  Flat source: not found"
    fi

    if [[ -f "$TOP" && -f "$BOTTOM" ]]; then
        echo "  Pair: ready (top.png + bottom.png)"
    else
        echo "  Pair: not generated"
    fi
fi
